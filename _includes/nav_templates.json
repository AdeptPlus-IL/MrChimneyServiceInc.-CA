{
  "nav_item": "<a href=\"{{href}}\" class=\"hover:text-primary transition-colors duration-300\">{{label}}</a>",
  "nav_dropdown": "<div class=\"relative group\">\n                <button id=\"dropdown-{{slug}}-trigger\" class=\"duration-300 flex items-center gap-1 cursor-pointer bg-transparent border-none\">\n                    {{label}}\n                    <svg class=\"w-3.5 h-3.5 transition-transform duration-200\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n                        <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M19 9l-7 7-7-7\"></path>\n                    </svg>\n                </button>\n                <div id=\"dropdown-{{slug}}\" class=\"absolute top-full left-0 mt-2 w-56 bg-white rounded-xl shadow-lg border border-gray-100 py-2 opacity-0 invisible transition-all duration-200 z-50\">\n                    <!-- DROPDOWN_ITEMS -->\n                </div>\n            </div>",
  "footer_nav_item": "<a href=\"{{href}}\" class=\"text-white text-[16px] leading-[24px] hover:text-primary transition-colors\">{{label}}</a>",
  "nav_dropdown_item": "<a href=\"{{href}}\" class=\"block px-4 py-2.5 text-sm text-gray-600 hover:bg-gray-50 hover:text-gray-900 transition-colors\">{{label}}</a>",
  "mobile_nav_dropdown": "<div class=\"border-b border-gray-100\">\n                    <div class=\"block py-3 text-sm font-medium text-gray-700\">{{label}}</div>\n                    <div class=\"flex flex-col pl-4 pb-2\">\n                        <!-- MOBILE_DROPDOWN_ITEMS -->\n                    </div>\n                </div>",
  "mobile_nav_dropdown_item": "<a href=\"{{href}}\" class=\"block py-2 text-sm text-gray-500 hover:text-gray-900 transition-colors\">{{label}}</a>"
}